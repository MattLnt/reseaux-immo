generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(AGENCE)
  agenceId  String?  @unique
  agence    Agence?  @relation(fields: [agenceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  AGENCE
}

model Agence {
  id          String   @id @default(cuid())
  nom         String
  adresse     String
  telephone   String
  email       String
  logo        String?
  photo       String?
  horaire     String?  @db.Text
  description String?  @db.Text
  
  // Validation admin
  isActive    Boolean  @default(false)
  
  // Relations
  user             User?
  biens            Bien[]
  acheteurs        Acheteur[]
  conversationsA   Conversation[] @relation("AgenceA")
  conversationsB   Conversation[] @relation("AgenceB")
  messagesEnvoyes  Message[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Bien {
  id          String   @id @default(cuid())
  agenceId    String
  agence      Agence   @relation(fields: [agenceId], references: [id], onDelete: Cascade)
  
  // Infos principales
  prix            Int
  localisation    String
  nbrChambres     Int
  nbrSdb          Int
  m2Terrain       Int?
  m2Habitable     Int
  photos          String[]
  
  // Infos optionnelles
  rendementLocatif  Float?
  peb               PEB?
  revenuCadastral   Int?
  descriptionCourte String?  @db.Text
  
  // Commission & détails
  tauxCommission  Float
  partRetrocedee  Int       @default(30)
  typeBien        TypeBien
  etatBien        EtatBien
  lienAnnonce     String?
  
  // Statut
  statut      StatutBien @default(ACTIF)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  @@index([statut])
  @@index([typeBien])
  @@index([prix])
  @@index([localisation])
}

enum PEB {
  A_PLUS
  A
  B
  C
  D
  E
  F
  G
}

enum TypeBien {
  APPARTEMENT
  MAISON
  VILLA
  BUREAU
  IMMEUBLE
  AUTRE
}

enum EtatBien {
  OCCASION
  NEUF
  PROJET
  AUTRE
}

enum StatutBien {
  ACTIF
  ARCHIVE
  SUPPRIME
}

model Acheteur {
  id              String   @id @default(cuid())
  agenceId        String
  agence          Agence   @relation(fields: [agenceId], references: [id], onDelete: Cascade)
  
  // Identité (privée — jamais affichée aux autres agences)
  prenom          String
  nom             String
  email           String
  telephone       String
  
  // Critères de recherche
  budgetMin       Int
  budgetMax       Int
  zones           String[]
  typesBien       TypeBien[]
  nbrChambresMin  Int?
  nbrSdbMin       Int?
  m2HabitableMin  Int?
  
  // Profil
  profilMenage    ProfilMenage
  remarques       String?       @db.Text
  
  // RGPD
  consentementRGPD Boolean      @default(false)
  
  // Statut
  statut          StatutAcheteur @default(ACTIF)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([agenceId])
  @@index([statut])
}

enum ProfilMenage {
  CELIBATAIRE
  COUPLE_SANS_ENFANT
  COUPLE_AVEC_ENFANTS
  FAMILLE
  INVESTISSEUR
  AUTRE
}

enum StatutAcheteur {
  ACTIF
  INACTIF
  TROUVE
}

model Conversation {
  id          String   @id @default(cuid())
  
  // Les 2 agences participantes
  agenceAId   String
  agenceA     Agence   @relation("AgenceA", fields: [agenceAId], references: [id], onDelete: Cascade)
  
  agenceBId   String
  agenceB     Agence   @relation("AgenceB", fields: [agenceBId], references: [id], onDelete: Cascade)
  
  messages    Message[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([agenceAId])
  @@index([agenceBId])
}

model Message {
  id              String   @id @default(cuid())
  
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  senderId        String   // agenceId de l'expéditeur
  sender          Agence   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  content         String?  @db.Text
  attachmentUrl   String?
  attachmentName  String?
  
  readAt          DateTime?
  
  createdAt       DateTime @default(now())
  
  @@index([conversationId])
  @@index([senderId])
}